{
  "name": "substack-publisher-mcp",
  "version": "1.0.0",
  "description": "MCP server for Substack's official Publisher API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "substack-publisher-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "llms-install.md"
  ],
  "mcpName": "io.github.dkships/substack-publisher-mcp",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --import tsx --test src/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "substack",
    "newsletter",
    "api",
    "analytics",
    "claude",
    "model-context-protocol"
  ],
  "author": "David Kelly <contact@dmkthinks.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkships/substack-publisher-mcp.git"
  },
  "homepage": "https://github.com/dkships/substack-publisher-mcp",
  "bugs": {
    "url": "https://github.com/dkships/substack-publisher-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
